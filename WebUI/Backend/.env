# WhatsUp Automation Backend Environment Variables
# Copy this file to .env and update the values as needed

# ================= DATABASE CONFIGURATION =================
# Database connection string (overrides db_connection.json and default)
# WUG_DB_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=localhost;Database=WhatsUp;UID=maxor;PWD=MAXOR321;Encrypt=yes;TrustServerCertificate=yes;

# ================= JWT CONFIGURATION =================
# JWT secret key (change in production, minimum 32 characters)
WUG_JWT_SECRET=your-secret-key-change-in-production-min-32-chars

# ================= REPORT SCHEDULER =================
# Enable/disable report scheduler
WUG_REPORT_SCHEDULER_ENABLED=true
# Interval in seconds between report runs
WUG_REPORT_SCHEDULER_INTERVAL_SECONDS=300

# Active Directory LDAP
WUG_AD_URL=ldap://maxoregypt.xyz:389
WUG_AD_GROUP_DN=CN=MaxorWUG,OU=MaxorGroups,DC=maxoregypt,DC=xyz
WUG_AD_SERVICE_BIND_DN=CN=wug,OU=MaxorServices,DC=maxoregypt,DC=xyz
WUG_AD_SERVICE_PASSWORD=Maxor123!

# Where to search for users (your OU of users)
WUG_AD_USER_SEARCH_BASE_DN=OU=MaxorUsers,DC=maxoregypt,DC=xyz

# Optional: set true only if your DC requires STARTTLS on plain ldap://
WUG_AD_USE_STARTTLS=false

# Optional: print LDAP debug to console (true/false)
WUG_AD_DEBUG=false

# Optional: try (&(objectCategory=person)(objectClass=user)...) if the simple filter misses
WUG_AD_TRY_OBJECT_CATEGORY_FILTER=true


# ================= ROUTER SCRIPTS CONFIGURATION =================
# File paths for router scripts (relative to scripts/routers/ directory)
# WUG_ROUTERS=routers.txt
# WUG_TASKS=tasks.txt
# WUG_ROUTERS_FILE=routers.txt
# WUG_CONFIG_FILE=config.txt

# ================= SSH CREDENTIALS =================
# Default SSH credentials for router connections
WUG_SSH_USER=admin
WUG_SSH_PASS=maxor
WUG_SSH_ENABLE=MAXOR321

# ================= EMAIL CONFIGURATION =================
# SMTP settings for email notifications
WUG_SMTP_SERVER=smtp-relay.brevo.com
WUG_SMTP_PORT=587
WUG_BREVO_USERNAME=9c44f9001@smtp-brevo.com
WUG_BREVO_SMTP_KEY=q3bw9TXCtpLU4Qhj
WUG_EMAIL_SENDER=snipergolden1234@gmail.com
WUG_EMAIL_RECEIVER=snipergolden1234@gmail.com