# Copy to ".env" in this folder (WebUI/Backend) and fill in secrets.
# main.py loads this file automatically (not only when cwd is this directory).

# Active Directory LDAP
WUG_AD_URL=ldap://maxoregypt.xyz:389
WUG_AD_GROUP_DN=CN=MaxorWUG,OU=MaxorGroups,DC=maxoregypt,DC=xyz
WUG_AD_SERVICE_BIND_DN=CN=wug,OU=MaxorServices,DC=maxoregypt,DC=xyz
WUG_AD_SERVICE_PASSWORD=Maxor123!

# Where to search for users (your OU of users)
WUG_AD_USER_SEARCH_BASE_DN=OU=MaxorUsers,DC=maxoregypt,DC=xyz

# Optional: set true only if your DC requires STARTTLS on plain ldap://
WUG_AD_USE_STARTTLS=false

# Optional: print LDAP debug to console (true/false)
WUG_AD_DEBUG=false

# Optional: try (&(objectCategory=person)(objectClass=user)...) if the simple filter misses
WUG_AD_TRY_OBJECT_CATEGORY_FILTER=true
